senate_data <- read_dta("/Users/ianmayhood/Desktop/ECO4422/election.dta")
mod_simple <- lm(vote ~ margin, data = senate_data)
coeftest(mod_simple, vcov = vcovHC(mod_simple, type = "HC1"))
coeftest(mod_simple, vcovHC)
ggplot(senate_data, aes(x = margin, y = vote)) +
geom_point() +
geom_vline(xintercept = 0, linetype = "dotted", color = "red")
senate_data <- senate_data %>%
mutate(treatment = ifelse(margin >= 0, 1, 0))
senate_data
mod_linear <- lm(vote ~ treatment * margin, data = senate_data)
coeftest(mod_linear, vcov = vcovHC)
mod_quad <- lm(vote ~ treatment * margin + treatment * I(margin^2), data = senate_data)
coeftest(mod_quad, vcov = vcovHC)
senate_sub <- senate_data %>%
filter(abs(margin) <= 25)
mod_linear_sub <- lm(vote ~ treatment * margin, data = senate_sub)
mod_linear_sub <- lm(vote ~ treatment * margin, data = senate_sub)
coeftest(mod_linear_sub, vcov = vcovHC)
mod_quad_sub <- lm(vote ~ treatment * margin + treatment * I(margin^2), data = senate_sub)
coeftest(mod_quad_sub, vcov = vcovHC)
